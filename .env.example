# ╔══════════════════════════════════════════════════════════════════════╗
# ║  AEF2 — Local AI Stack  |  Environment Configuration               ║
# ║  Copy to .env and fill in all values marked <CHANGE_ME>            ║
# ║  Secrets must be set — stack will refuse to start without them      ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Project ────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=aef2
TZ=Etc/UTC
PUID=1000
PGID=1000
DATA_ROOT=./data
# Host LAN IP the stack binds/advertises on — auto-detected by onboard.sh at
# bootstrap (see detect_host_ip() in generate_env()); set explicitly here only
# to override.
HOST_IP=<CHANGE_ME>

# ── Profiles (comma-separated, choose what to run) ─────────────────────
# core        — always required (postgres, redis, qdrant, ollama, litellm,
#               hermes, open-webui, mcpo, mcp-servers, searxng, homepage)
# knowledge   — trilium, affine, anything-llm, docling
# automation  — n8n, flowise
# memory      — mem0, open-interpreter
# extras      — weaviate, chromadb (additional vector stores)
# observability — langfuse, dozzle
# tools       — portainer, cloudbeaver
# DOCKER_COMPOSE_PROFILES=core,knowledge,automation,memory,observability,tools

# ════════════════════════════════════════════════════════════════════════
#  LAYER 1 — CORE DATABASES
# ════════════════════════════════════════════════════════════════════════

# ── PostgreSQL (backbone for n8n, AFFiNE, Flowise, Langfuse) ──────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=aef2
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=aef2
# Per-service databases (auto-created by init scripts)
POSTGRES_DB_N8N=n8n
POSTGRES_DB_AFFINE=affine
POSTGRES_DB_FLOWISE=flowise
POSTGRES_DB_LANGFUSE=langfuse
POSTGRES_DB_MEM0=mem0
POSTGRES_DB_LITELLM=litellm

# ── Redis (queues + sessions for n8n, Open WebUI) ─────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_ME>

# ── SurrealDB (multi-model: Hermes graph memory + app data) ───────────
SURREALDB_HOST=surrealdb
SURREALDB_PORT=8000
SURREALDB_USER=root
SURREALDB_PASS=<CHANGE_ME>
# NOTE (resolved 2026-07-13): SURREALDB_PASSWORD naming drift is closed. SURREALDB_PASS is the
# ONE canonical name (used by surrealdb.yml's --pass flag, mcp-servers.yml, hermes.yml). Nothing
# in the stack reads SURREALDB_PASSWORD anymore (config/mcpo/config.json's tools-profile
# surrealdb entry was already dropped in T-0041) — the var was removed here and from
# scripts/onboard.sh's INTERNAL_SECRETS to stop generating a dead, unread secret.
SURREALDB_NS=aef
SURREALDB_DB=hermes

# ════════════════════════════════════════════════════════════════════════
#  LAYER 2 — VECTOR STORES
# ════════════════════════════════════════════════════════════════════════

# ── Qdrant (primary vector store — Hermes, Mem0, AnythingLLM) ─────────
QDRANT_HOST=qdrant
QDRANT_PORT_HTTP=6333
QDRANT_PORT_GRPC=6334
QDRANT_API_KEY=<CHANGE_ME>

# ── ChromaDB (extras profile — dev/experimental RAG) ──────────────────
CHROMADB_HOST=chromadb
CHROMADB_PORT=8200
CHROMADB_AUTH_TOKEN=<CHANGE_ME>

# ── Weaviate (extras profile — hybrid vector+keyword search) ───────────
WEAVIATE_HOST=weaviate
WEAVIATE_HTTP_PORT=8280
WEAVIATE_GRPC_PORT=50051

# ════════════════════════════════════════════════════════════════════════
#  LAYER 3 — LLM INFRASTRUCTURE
# ════════════════════════════════════════════════════════════════════════

# ── Ollama (local model server) ────────────────────────────────────────
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
# The one model onboard.sh's ensure_local_model() actually auto-pulls on first
# start (see "the long pole of the install" step). OLLAMA_EMBED_MODEL/
# OLLAMA_CODE_MODEL/OLLAMA_VISION_MODEL were removed 2026-07-16: declared here
# but never read by any compose service or script (grepped compose/, agents/,
# ceo/, pm/, scripts/ — zero hits), and OLLAMA_CODE_MODEL defaulted to a ~20GB
# 32b model that would have made a real "pull everything" implementation
# violate the FREE-BY-DEFAULT fast-onboarding doctrine. Re-add only alongside
# the service that actually consumes it.
OLLAMA_DEFAULT_MODEL=llama3.2:latest

# ── LiteLLM (single LLM gateway — ALL services route through here) ─────
LITELLM_HOST=litellm
LITELLM_PORT=4000
LITELLM_MASTER_KEY=<CHANGE_ME>
LITELLM_SALT_KEY=<CHANGE_ME>
# Internal service key (used by Hermes, n8n, Flowise, etc.)
LITELLM_API_KEY=<CHANGE_ME>
# LiteLLM DB (uses shared postgres)
LITELLM_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/litellm

# ── External API Keys (optional — leave blank to use Ollama only) ──────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GOOGLE_API_KEY is read by config/litellm/setup-default-config.yaml; the running
# litellm.yml uses the GEMINI_API_KEY_* numbered slots below. Fill whichever your
# active config references.
GOOGLE_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# GROQ_API_KEY is read by litellm.yml (env GROQ_API_KEY_1 <- host GROQ_API_KEY).
# GROQ_API_KEY_1 also exists as a raw slot — keep both until the mapping is unified.
GROQ_API_KEY=
GROQ_API_KEY_1=
DEEPSEEK_KEY_1=
DEEPSEEK_KEY_2=
OPENROUTER_KEY_1=
OPENROUTER_KEY_2=
OPENROUTER_KEY_3=
NOVITA_KEY_1=
ALIBABA_MODELSTUDIO_KEY_1=
# NVIDIA NIM (added 2026-07-09 for LiteLLM Tier-3 fallback) — paste key value here
NVIDIA_NIM_API_KEY=

# ════════════════════════════════════════════════════════════════════════
#  LAYER 4 — HERMES AGENT GATEWAY
# ════════════════════════════════════════════════════════════════════════

HERMES_HOST=hermes
HERMES_PORT=8642
# Key that Open WebUI + other services use to talk to Hermes
HERMES_API_KEY=<CHANGE_ME>
# Default model routed via LiteLLM
HERMES_DEFAULT_MODEL=llama3.2:latest
HERMES_EMBEDDING_MODEL=nomic-embed-text:latest
# Persona / display name — rendered into agents/hermes/SOUL.md by
# agents/hermes/render-soul.sh (run this after changing either value here).
HERMES_NAME=Hermes
PRODUCT_NAME=Enclave
# SurrealDB namespace/db for Hermes's own graph memory
HERMES_SURREAL_NS=aef
HERMES_SURREAL_DB=hermes

# ════════════════════════════════════════════════════════════════════════
#  LAYER 5 — AGENT FRAMEWORKS & TOOLS
# ════════════════════════════════════════════════════════════════════════

# ── Open WebUI (primary chat UI) ───────────────────────────────────────
OPENWEBUI_PORT=3000
OPENWEBUI_SECRET=<CHANGE_ME>
OPENWEBUI_ENABLE_SIGNUP=false
# Security hardening (2026-07-16): Open WebUI grants admin to whoever calls
# /api/v1/auths/signup FIRST, regardless of ENABLE_SIGNUP — that check only
# blocks the *second* signup onward. scripts/init-openwebui-admin.sh claims
# this account immediately at bring-up so a LAN visitor never can.
OPENWEBUI_ADMIN_EMAIL=admin@local.dev
OPENWEBUI_ADMIN_NAME=Admin
OPENWEBUI_ADMIN_PASSWORD=<CHANGE_ME>
# Auto-generated + persisted here by scripts/init-openwebui-admin.sh (#11) --
# a real per-instance API key the Homepage dashboard widget uses to read
# Open WebUI's /api/v1/models. Leave blank; the script fills it in idempotently.
OPENWEBUI_API_KEY=

# ── n8n (automation — automation profile) ─────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_ENCRYPTION_KEY=<CHANGE_ME_32CHARS>
N8N_DB=n8n
# Owner-account bootstrap (closes T-0042's n8n half — first LAN visitor no longer
# claims the owner account). scripts/init-n8n-owner.sh calls POST /rest/owner/setup
# with these once n8n is healthy. Idempotent: a no-op if an owner already exists.
N8N_OWNER_EMAIL=admin@example.com
N8N_OWNER_FIRST_NAME=Admin
N8N_OWNER_LAST_NAME=Operator
N8N_OWNER_PASSWORD=<CHANGE_ME>

# ── Flowise (visual flow builder — automation profile) ─────────────────
FLOWISE_PORT=3100
# #8: env-based basic auth (FLOWISE_USERNAME/PASSWORD as container env vars)
# does nothing against the pinned v3.1.2 image — real bootstrap is
# scripts/init-flowise-admin.sh, which registers this as the org owner.
FLOWISE_ADMIN_NAME=admin
FLOWISE_ADMIN_EMAIL=admin@local.dev
FLOWISE_PASSWORD=<CHANGE_ME>
FLOWISE_SECRET_KEY=<CHANGE_ME>

# ── Open Interpreter (code execution — memory profile) ─────────────────
OI_PORT=8143
OI_MODEL=qwen2.5-coder:32b

# ── Mem0 (persistent memory layer — memory profile) ────────────────────
MEM0_PORT=8888
MEM0_DB=mem0

# ── AnythingLLM (RAG workspace — knowledge profile) ────────────────────
ANYTHINGLLM_PORT=3200
ANYTHINGLLM_JWT=<CHANGE_ME>
ANYTHINGLLM_MODEL=llama3.2:latest

# ── Docling (doc parsing — knowledge profile) ──────────────────────────
DOCLING_PORT=5001
DOCLING_WORKERS=2

# ── SearXNG (private search — core) ────────────────────────────────────
SEARXNG_PORT=8081
SEARXNG_SECRET=<CHANGE_ME>
# config/searxng/settings.yml reads ${SEARXNG_SECRET_KEY}, which the compose file
# sets INSIDE the container from SEARXNG_SECRET. Do not set this on the host.
# SEARXNG_SECRET_KEY=<set by compose from SEARXNG_SECRET>

# ── MCPO (MCP → OpenAI bridge — core) ─────────────────────────────────
MCPO_PORT=8080
MCPO_API_KEY=<CHANGE_ME>

# ── MCP Server ports (all internal, exposed for debugging only) ─────────
MCP_FS_PORT=3701
MCP_MEMORY_PORT=3702
MCP_FETCH_PORT=3703
MCP_GITHUB_PORT=3704
MCP_PG_PORT=3705
MCP_SURREAL_PORT=3706
MCP_DOCKER_PORT=3707

# ── GitHub (used by mcp-github server) ─────────────────────────────────
GITHUB_TOKEN=

# ════════════════════════════════════════════════════════════════════════
#  LAYER 6 — KNOWLEDGE & PRODUCTIVITY
# ════════════════════════════════════════════════════════════════════════

# ── AFFiNE (Notion+Miro alt — knowledge profile) ──────────────────────
AFFINE_PORT=3010
AFFINE_DB=affine
# SECURITY FINDING (2026-07-13, verified against AFFiNE v0.26.7 source): these two
# vars are NOT consumed anywhere by the affine/affine-migration images — dead
# config, not a working bootstrap. AFFiNE's only first-user path is email
# magic-link sign-up (MAILER_HOST is blank below, so it cannot fire) or an
# already-authenticated admin calling the `createUser` GraphQL mutation — a
# chicken-and-egg problem for the very first account. No safe non-interactive
# bootstrap exists without either (a) wiring a real SMTP relay so magic-link
# sign-up works, or (b) an Engineering-built in-container CLI command that reuses
# AFFiNE's own Models.user.create()+FeatureService.addAdmin() so the
# `user.postCreated` side effects (default workspace, etc.) aren't skipped.
# Kept here as documentation of intent only — do not assume these do anything.
AFFINE_ADMIN_EMAIL=admin@example.com
AFFINE_ADMIN_PASSWORD=<CHANGE_ME>

# ── Trilium Notes (second brain — knowledge profile) ───────────────────
TRILIUM_PORT=8190
# Admin password set during headless first-run init (also used for ETAPI login).
TRILIUM_PASSWORD=change-me-strong-password

# ════════════════════════════════════════════════════════════════════════
#  LAYER 7 — OBSERVABILITY & TOOLING
# ════════════════════════════════════════════════════════════════════════

# ── Langfuse (LLM tracing — observability profile) ─────────────────────
LANGFUSE_PORT=3300
LANGFUSE_SECRET_KEY=<CHANGE_ME_openssl_rand_hex_32>
LANGFUSE_ENCRYPTION_KEY=<CHANGE_ME_openssl_rand_hex_32>
LANGFUSE_DB=langfuse
# Public/secret key pair for SDK instrumentation
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-<CHANGE_ME>
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-<CHANGE_ME>
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=<CHANGE_ME>

# ── Dozzle (log viewer — observability profile) ─────────────────────────
DOZZLE_PORT=9999
# Security hardening (2026-07-13): DOZZLE_AUTH_PROVIDER=simple now requires these.
# scripts/init-dozzle-auth.sh generates config/dozzle/users.yml (bcrypt hash) from
# them — the container never receives the plaintext password as an env var.
DOZZLE_AUTH_USER=admin
DOZZLE_AUTH_PASSWORD=<CHANGE_ME>

# ── CloudBeaver (DB management UI — tools profile) ─────────────────────
CLOUDBEAVER_PORT=8978
CLOUDBEAVER_ADMIN_USER=cbadmin
CLOUDBEAVER_ADMIN_PASSWORD=<CHANGE_ME>

# ── Portainer (Docker management — tools profile) ──────────────────────
PORTAINER_HTTP_PORT=9000
PORTAINER_HTTPS_PORT=9443
# Security hardening (2026-07-13): pre-seeds the first-run admin account so the
# ~5min LAN-wide claim race no longer exists. scripts/init-portainer-auth.sh writes
# this into config/portainer/admin_password (plaintext file, Portainer hashes it
# internally on first boot only — see --admin-password-file in portainer.yml).
PORTAINER_ADMIN_PASSWORD=<CHANGE_ME>

# ── Homepage (dashboard — core) ────────────────────────────────────────
HOMEPAGE_PORT=3030

# ════════════════════════════════════════════════════════════════════════
#  LAYER 8 — EDGE / INGRESS & NOTIFICATIONS
# ════════════════════════════════════════════════════════════════════════

# ── Cloudflare (DNS + Tunnel ingress) ──────────────────────────────────
CLOUDFLARE_EMAIL=
CLOUDFLARE_GLOBAL_API_KEY=
CLOUDFLARE_ALL_DNS_ZONE_KEY=
# Named-tunnel credential for cloudflared (paste token value here)
CLOUDFLARE_TUNNEL_TOKEN=

# ── Telegram (bot notifications) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ID=

# ── Registrar (governance plane) ──
REGISTRAR_PORT=8090
# When set, X-Company: * (hub scope) requires this token
REGISTRAR_ADMIN_TOKEN=
UX_VALIDATE_PORT=8091
