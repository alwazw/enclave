# =====================================================================
# config.env - Global Configuration Controls for ubuntu-customz Suite
# =====================================================================

# Module Feature Toggles (1 = Enabled, 0 = Disabled)
EXEC_PRIVILEGES=1
EXEC_ENVIRONMENT=1
EXEC_TOOLS=1
EXEC_OPTIMIZATION=1
EXEC_STITCH=1

# Targeted User Definitions (Fixes Blanket Sudo Permissions)
# Honor a pre-set TARGET_USER/TARGET_HOME if the caller already resolved it.
# This is essential for modules launched via nested `sudo -u <user>`: that inner
# sudo rewrites SUDO_USER to "root", so re-deriving from SUDO_USER here would
# wrongly resolve to root. The orchestrator passes the real target through env.
TARGET_USER="${TARGET_USER:-${SUDO_USER:-$USER}}"
TARGET_HOME="${TARGET_HOME:-$(eval echo "~$TARGET_USER")}"

# Log Tracing Setup
LOG_FILE="/var/log/ubuntu-customz-deploy.log"
