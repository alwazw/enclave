# ==========================================================
# 1. Secrets (Always ignore local secrets!)
# ==========================================================
.env
# Postgres backups: dumps contain token/verification tables — never commit.
backups/

*.env.local
*.env.*.local
# Any nested/service-scoped env file, EXCEPT placeholder scaffolds
**/.env
**/*.env
# Private keys, certs, and provider credential blobs
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
*_rsa
# Cloudflared named-tunnel credentials (JSON creds + cert)
cert.pem
cloudflared*.json
*tunnel*creds*.json
credentials.json
secrets.yaml
secrets.yml
# Generated auth material for dev-tools/observability admin bootstrap — bcrypt
# hash / plaintext-password-file, both credential-bearing, never committed.
config/dozzle/users.yml
config/portainer/admin_password
# Never ignore the placeholder scaffolds (must stay committable)
!*.env.example
!*.env.template
!.env.example
!.env.template
!config/dozzle/users.yml.example
!config/portainer/admin_password.example

# ==========================================================
# 2. Dependency Parity (Let package-lock.json handle this)
# ==========================================================
node_modules/
jspm_packages/
web_modules/

# Keep package-lock.json so everyone builds the EXACT same packages
!package-lock.json

# ==========================================================
# 3. Docker Runtime Volumes (Avoid DB lock crashes)
# ==========================================================
data/
compose/*/data/
*.db
*.sqlite

# ==========================================================
# 4. System Logs & Cache
# ==========================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.DS_Store
Thumbs.db

# ==========================================================
# 5. Build Artifacts & Output
# ==========================================================
# Scrubbed public showcase template — regenerated by scripts/build-showcase.sh,
# reviewed by the CEO out-of-band, never committed to this private repo.
showcase-build/
/dist
/build
/out
/target
/tmp
*.log
*.bak
*.swp
*.swo

# ==========================================================
# 6. IDE and Editor Specific Files
# ==========================================================
.vscode/
.vscode-server/
.local/
.idea/
*.iml
.DS_Store
.history/
.project
.settings/
.classpath
*.sublime-project
*.sublime-workspace

# ==========================================================
# 7. OS Specific Files
# ==========================================================
.Trash-*
ehthumbs.db
.Spotlight-V100
.TemporaryItems
.com.apple.timemachine.donotpresent

# ==========================================================
# 8. Qwen Code internal files
# ==========================================================
.qwen/

# ==========================================================
# 9. Various common ignore patterns that are outside the current project directory
#    These are specifically added to clean up the `git status` output
# ==========================================================


# runtime logs
logs/

# relocated backups (2026-07-14)
backups
backups.old-pre-relocation/

.venv/
__pycache__/
