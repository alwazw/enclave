# -------------------
# Format: KEY="VALUE"
# -------------------

# ---- System Maintenance ----
update='sys_update'
fix='sys_update'
clean='sys_update'
install='apt_install'
reboot='sudo reboot'
shutdown='sudo shutdown -h now'
sctl='sudo systemctl'
s-status='sudo systemctl status'
s-start='sudo systemctl start'
s-stop='sudo systemctl stop'
s-restart='sudo systemctl restart'
s-logs='sudo journalctl -xeu'

# ---- File Safety ----
rm='rm -I'
cp='cp -i'
mv='mv -i'
chmod='sudo chmod'
chown='sudo chown'
kill='sudo kill -9'

# ---- Navigation & Listing ----
..='cd ..'
...='cd ../..'
....='cd ../../..'
cls='clear'
ls='ls -alF --color=auto'
ll='ls -alF'
la='ls -A --color=auto'
lr='ls -R'
l='ls -CF --color=auto'
cd() { builtin cd "$@" && ls -alF --color=auto; }

# ---- Tree Utilities ----
tree='tree -L 1 -laC'
tree2='tree -L 2 -laC'
tree3='tree -L 3 -laC'

# ---- Grep ----
grep='grep --color=auto'

# ---- Network ----
myip='curl -s ifconfig.me && echo'
ports='ss -tulnp'
ip='ip a'
route='mtr'
ping='ping -c 5'

# ---- Docker ----
dps='docker ps -a'
dcup='docker compose up -d'
dcd='docker compose down'
dcup-env='docker compose --env-file .env -d'
dcup-env-secrets='docker compose --env-file .env --env-file .secrets up -d'
dcup-ai='docker compose -f ai-stack.yml up -d'
dcd-ai='docker compose -f ai-stack.yml down'
dlogs='docker logs -f'
dexec='docker exec -it'
dimg='docker images'
dnet='docker network ls'
nanod='nano docker-compose.yml'
catd='cat docker-compose.yml'
rm-dps='echo "Stopping & removing all containers..." && docker rm -f $(docker ps -aq)'
rm-dimg='echo "Removing all images..." && docker rmi -f $(docker images -aq)'

# ---- Zellij Multiplexer ----
zj='zellij'
zja='zellij attach'
mup='zellij options --default-layout compact'

# ---- Misc Utilities ----
open='xdg-open'
df='df -h'
free='free -h'
