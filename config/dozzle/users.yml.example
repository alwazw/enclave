# Placeholder scaffold — the real config/dozzle/users.yml is generated by
# scripts/init-dozzle-auth.sh and is gitignored (contains a bcrypt password hash).
#
# Format Dozzle expects (DOZZLE_AUTH_PROVIDER=simple), per current upstream docs:
users:
  admin:
    email: admin@example.com
    name: Admin
    # bcrypt hash only — NEVER a plaintext password. Generate with:
    #   docker run --rm amir20/dozzle:latest generate admin --password '<pw>' \
    #     --email admin@example.com --name Admin
    password: <CHANGE_ME_BCRYPT_HASH>
    filter: ""
    roles: ""
